# TinyDx MCP — Environment Variables
# Copy this to .env and fill in your values
# Power of 15 Rule 14: NEVER commit .env to version control

# Required
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# FHIR Server (defaults to HAPI public test server)
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# OMIM API Key (free for research — request at https://www.omim.org/api)
OMIM_API_KEY=

# Knowledge APIs (defaults provided)
HPO_API_BASE=https://clinicaltables.nlm.nih.gov/api/hpo/v3
ORPHANET_API_BASE=https://api.orphadata.com

# Server
PORT=3000
